# Configurações globais compartilhadas por todos os bots.
# Copie para config.global e preencha os valores:
#   cp config.global.example config.global

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Chave da API Anthropic — opcional se usar assinatura do Claude Code.
# Se vazio, bot.py lê automaticamente ~/.claude/.credentials.json (OAuth).
ANTHROPIC_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Chave da API OpenRouter — necessária quando algum bot usa PROVIDER=openrouter.
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Provedor padrão ───────────────────────────────────────────────────────────
# anthropic  → Claude via Anthropic API key (requer ANTHROPIC_API_KEY)
# openrouter → Qualquer modelo via OpenRouter (requer OPENROUTER_API_KEY)
# claude-cli → Claude via OAuth do Claude Code (sem API key, usa assinatura Claude)
# Cada bot pode sobrescrever com PROVIDER= no seu .env
PROVIDER=claude-cli

# ── Telegram ──────────────────────────────────────────────────────────────────
# Seu ID do Telegram (admin de todos os bots)
# Para descobrir: inicie qualquer bot e envie /id
ADMIN_ID=SEU_ID_TELEGRAM_AQUI

# ── Modelo ────────────────────────────────────────────────────────────────────
# Modelo padrão para todos os bots.
# Anthropic:   claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenRouter:  x-ai/grok-3 | google/gemini-2.0-flash | openai/gpt-4o | etc.
MODEL=claude-opus-4-6

# ── Acesso ────────────────────────────────────────────────────────────────────
# Modo de acesso padrão: open | approval | closed
ACCESS_MODE=approval

# ── Bug Fixer Agent ───────────────────────────────────────────────────────────
# Agente de sistema que detecta e corrige erros nos bots automaticamente.
# Ativado via painel admin → Config Global → Sistema.
BUGFIXER_ENABLED=true
BUGFIXER_TIMES_PER_DAY=1
# Token do bot Telegram usado para enviar notificações ao admin.
# Copie o TELEGRAM_TOKEN de qualquer bot em bots/<nome>/.env
BUGFIXER_TELEGRAM_TOKEN=

# ── Tracing detalhado ─────────────────────────────────────────────────────────
# Registra cada chamada LLM e tool call com timing e tokens granulares.
# Habilitado por padrão. Visualize via /trace no Telegram ou GET /api/bots/{name}/traces
TRACING_ENABLED=true

# ── Compactação de contexto ───────────────────────────────────────────────────
# Sumariza mensagens antigas em vez de simplesmente descartá-las.
# Desativado por padrão (opt-in) — requer OPENROUTER_API_KEY para sumarizar.
COMPACTION_ENABLED=false
# Modelo barato usado para sumarizar (via OpenRouter)
COMPACTION_MODEL=google/gemini-2.0-flash-001
# Quantas mensagens recentes preservar intactas ao compactar
COMPACTION_KEEP=10

# ── Painel Admin ─────────────────────────────────────────────────────────────
# Porta do painel admin (default: 8080)
ADMIN_PORT=8080
# URL pública do painel (auto-detectada se vazia)
ADMIN_PANEL_URL=
